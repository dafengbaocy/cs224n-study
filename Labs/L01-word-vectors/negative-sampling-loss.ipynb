    "U_context = np.random.randn(VOCAB_SIZE, DIM) * 0.1\n",
    "\n",
    "# Pick a (center, context) pair: \"king\" -> \"queen\" (semantically related)\n",
    "center_idx = VOCAB.index(\"king\")\n",
    "context_idx = VOCAB.index(\"queen\")\n",
